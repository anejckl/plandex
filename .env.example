# Copy this file to `.env` and fill in real values before running `docker compose up`.
# `.env` is gitignored — never commit real secrets.

# Postgres
POSTGRES_DB=plandex
POSTGRES_USER=plandex
POSTGRES_PASSWORD=change-me-to-a-strong-password

# JWT signing secret for the API — must be at least 32 characters.
# Generate one with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars-long
