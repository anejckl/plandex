* text=auto eol=lf

# Windows-specific files keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf
*.sln   text eol=crlf

# Shell scripts must be LF
*.sh    text eol=lf

# Binary files — never touched
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pfx   binary
*.woff  binary
*.woff2 binary
